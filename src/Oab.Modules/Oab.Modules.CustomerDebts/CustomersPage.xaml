<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:oab="clr-namespace:Oab.App.Localization;assembly=Oab.App"
             xmlns:local="clr-namespace:Oab.Modules.CustomerDebts"
             x:Class="Oab.Modules.CustomerDebts.CustomersPage"
             x:DataType="local:CustomersViewModel"
             Title="{oab:Tr Customers_Title}">
    <Grid>
        <CollectionView ItemsSource="{Binding Customers}" Margin="12">
            <CollectionView.EmptyView>
                <Label Text="{oab:Tr Customers_Empty}"
                       HorizontalOptions="Center" VerticalOptions="Center"
                       TextColor="Gray" Margin="24" />
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="local:CustomerRow">
                    <Border StrokeThickness="0" BackgroundColor="{AppThemeBinding Light=#F2F2F7, Dark=#2C2C2E}"
                            StrokeShape="RoundRectangle 12" Margin="0,4">
                        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" Padding="14" RowSpacing="6">
                            <Label Text="{Binding Party.Name}" FontAttributes="Bold" FontSize="16" />
                            <Label Grid.Row="1" Text="{Binding BalanceText}" TextColor="{Binding BalanceColor}" FontSize="14" />
                            <HorizontalStackLayout Grid.Row="2" Grid.ColumnSpan="2" Spacing="8" HorizontalOptions="End">
                                <Button Text="{oab:Tr Customers_RecordDebt}" Clicked="OnRecordDebtClicked" />
                                <Button Text="{oab:Tr Customers_CollectPayment}"
                                        IsVisible="{Binding OwesYou}"
                                        Clicked="OnCollectPaymentClicked" />
                            </HorizontalStackLayout>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Button Text="＋" FontSize="26" WidthRequest="60" HeightRequest="60" CornerRadius="30"
                HorizontalOptions="End" VerticalOptions="End" Margin="24"
                SemanticProperties.Description="{oab:Tr Customers_AddCustomer}"
                Clicked="OnAddCustomerClicked" />
    </Grid>
</ContentPage>
