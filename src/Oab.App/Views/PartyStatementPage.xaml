<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:oab="clr-namespace:Oab.App.Localization"
             xmlns:local="clr-namespace:Oab.App.Views"
             x:Class="Oab.App.Views.PartyStatementPage"
             x:DataType="local:PartyStatementViewModel"
             Title="{oab:Tr Statement_Title}">
    <Grid RowDefinitions="Auto,*">
        <VerticalStackLayout Padding="16,12" Spacing="2">
            <Label Text="{Binding PartyName}" FontSize="20" FontAttributes="Bold" />
            <Label Text="{Binding BalanceText}" TextColor="{Binding BalanceColor}" FontSize="16" />
        </VerticalStackLayout>

        <CollectionView Grid.Row="1" ItemsSource="{Binding Rows}" Margin="12,0,12,12">
            <CollectionView.EmptyView>
                <Label Text="{oab:Tr Statement_Empty}"
                       HorizontalOptions="Center" VerticalOptions="Center"
                       TextColor="Gray" Margin="24" />
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="local:StatementRow">
                    <Border StrokeThickness="0" BackgroundColor="{AppThemeBinding Light=#F2F2F7, Dark=#2C2C2E}"
                            StrokeShape="RoundRectangle 12" Margin="0,4">
                        <!-- Corrections are outlined, not hidden: a fixed accent reads on
                             both themes, and an edited-looking history is the point. -->
                        <!-- Tapping a row is the only way into the correction flow.
                             MAUI has no long-press gesture, and context flyouts are
                             Windows/macOS-only, so the tap opens a labelled action
                             sheet — which doubles as the thing that makes the feature
                             discoverable at all. -->
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnEntryTapped" />
                        </Border.GestureRecognizers>
                        <Border.Triggers>
                            <DataTrigger TargetType="Border" Binding="{Binding IsCorrection}" Value="True">
                                <Setter Property="Stroke" Value="Goldenrod" />
                                <Setter Property="StrokeThickness" Value="1.5" />
                            </DataTrigger>
                        </Border.Triggers>
                        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" Padding="14" RowSpacing="4">
                            <Label Text="{Binding KindText}" FontAttributes="Bold" FontSize="15" />
                            <Label Grid.Column="1" Text="{Binding AmountText}" FontSize="15" />
                            <Label Grid.Row="1" Text="{Binding DateText}" FontSize="12" TextColor="Gray" />
                            <Label Grid.Row="1" Grid.Column="1" Text="{Binding BalanceAfterText}"
                                   FontSize="12" TextColor="Gray" />
                            <Label Grid.Row="2" Grid.ColumnSpan="2" Text="{Binding NoteText}"
                                   IsVisible="{Binding HasNote}"
                                   FontSize="13" FontAttributes="Italic" TextColor="Gray" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
